{
  "name": "geminiorganizer",
  "private": true,
  "version": "1.1",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build:dev": "bun run scripts/build.js dev",
    "build:prod": "bun run scripts/build.js prod",
    "build:chrome": "bun run scripts/build.js prod chrome-mv3",
    "build:firefox": "bun run scripts/build.js prod firefox-mv3",
    "build:all": "bun run build:chrome && bun run build:firefox",
    "dev": "bun run scripts/watch.js",
