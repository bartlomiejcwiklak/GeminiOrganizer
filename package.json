    "dev:firefox": "bun run scripts/watch.js firefox-mv3",
    "zip:chrome": "bun run scripts/zip.js chrome-mv3",
    "zip:firefox": "bun run scripts/zip.js firefox-mv3",
    "clean": "bun run scripts/clean.js"
  },
  "devDependencies": {
    "archiver": "^7.0.1",
    "clean-css": "^5.3.3",
    "terser": "^5.31.0"
